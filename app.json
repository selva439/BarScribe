{
  "expo": {
    "name": "BarScribe",
    "slug": "ironlog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "barscribe",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.selva439.barscribe",
      "buildNumber": "3",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "BarScribe needs access to your photos to set a profile picture for workout share cards.",
        "NSCameraUsageDescription": "BarScribe needs camera access to take a profile photo for workout share cards.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.selva439.barscribe",
      "versionCode": 3,
      "adaptiveIcon": {
        "backgroundColor": "#0F0F0F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-notifications",
      "expo-sqlite",
      "expo-sharing",
      [
        "expo-image-picker",
        {
          "photosPermission": "BarScribe needs access to your photos to set a profile picture for workout share cards.",
          "cameraPermission": "BarScribe needs camera access to take a profile photo for workout share cards."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "44ad9cc0-c661-4f26-9a5b-e9c83a8a72ac"
      }
    },
    "owner": "selva439"
  }
}
